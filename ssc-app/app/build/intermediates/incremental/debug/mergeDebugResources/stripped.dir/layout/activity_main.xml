<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050510">

    <!-- WebView fills everything -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Offline / Error overlay -->
    <LinearLayout
        android:id="@+id/errorView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#050510"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="★"
            android:textColor="#FFD700"
            android:textSize="64sp" />

        <TextView
            android:id="@+id/errorTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.15"
            android:text="CONNECTION LOST"
            android:textAllCaps="true"
            android:textColor="#FF4455"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/errorMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Check your internet connection and try again"
            android:textColor="#888888"
            android:textSize="14sp" />

        <Button
            android:id="@+id/retryButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="#FFD700"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:paddingHorizontal="48dp"
            android:text="RETRY"
            android:textColor="#050510"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Splash overlay — shown while page loads -->
    <LinearLayout
        android:id="@+id/splashView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#050510"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="★"
            android:textColor="#FFD700"
            android:textSize="72sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.25"
            android:text="SLOT STARS CLUB"
            android:textAllCaps="true"
            android:textColor="#FFD700"
            android:textSize="24sp" />

        <ProgressBar
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="32dp"
            android:indeterminateTint="#FFD700" />

    </LinearLayout>

</FrameLayout>
